# 文译（Wenyi）环境变量样例。复制为 .env 后按需填写。

# ── LLM（内核：DeepSeek，OpenAI 兼容）──────────────────────────────
# 必填（否则翻译会因鉴权失败）。也可改 config.yaml 换其它兼容服务。
DEEPSEEK_API_KEY=

# ── 数据库 / 缓存（docker compose 已内置默认）──────────────────────
DATABASE_URL=postgresql://wenyi:wenyi@postgres:5432/wenyi
REDIS_URL=redis://redis:6379/0

# ── 数据卷（上传原件 / 导出成品）─────────────────────────────────
DATA_DIR=./data

# ── 可选静态 Token（v1 无用户系统；填了之后所有 HTTP 请求需带
#    Authorization: Bearer <token>，WebSocket 与 /health 除外）─────
WENYI_API_TOKEN=

# ── 前端 CORS（逗号分隔；默认放行所有源）─────────────────────────
WENYI_CORS_ORIGINS=*
